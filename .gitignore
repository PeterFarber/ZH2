# Build output
build/
out/*
!out/.gitkeep
.vcpkg/
vcpkg_installed/
.vs/
.idea/
CMakeUserPresets.json

# Notes
_notes/*
!_notes/.gitkeep

# Logs/temp
data/logs/*
!data/logs/.gitkeep
data/temp/*
!data/temp/.gitkeep

# OS/editor
.DS_Store
Thumbs.db
*.swp
*.swo
__pycache__/
*.py[cod]

