.serena/cache/
.serena/logs/
.serena/memories/
.codex/
.mcp.json

# Binaries
*.exe
*.dll
*.so
*.dylib
*.pdb
*.ilk
*.obj
*.o
*.a
*.lib


# _save
_save/

