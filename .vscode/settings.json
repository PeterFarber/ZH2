{
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    "editor.rulers": [
        100,
        120
    ],
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.associations": {
        "*.h": "cpp",
        "*.hpp": "cpp",
        "*.hh": "cpp",
        "*.hxx": "cpp",
        "*.inl": "cpp",
        "*.ipp": "cpp",
        "*.vert": "glsl",
        "*.frag": "glsl",
        "*.comp": "glsl",
        "*.geom": "glsl",
        "*.tesc": "glsl",
        "*.tese": "glsl",
        "*.glsl": "glsl",
        "CMakeLists.txt": "cmake"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.cache": true,
        // "**/build": true,
        // "**/build-*": true,
        // "**/out": true
    },
    "search.exclude": {
        "**/build": true,
        "**/build-*": true,
        "**/out": true,
        "**/external": true,
        "**/third_party": true,
        "**/.cache": true
    },
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--clang-tidy",
        "--completion-style=detailed",
        "--header-insertion=iwyu",
        "--pch-storage=memory",
        "--pretty"
    ],
    "clangd.checkUpdates": false,
    "cmake.useCMakePresets": "always",
    "cmake.configureOnOpen": true,
    "cmake.buildBeforeRun": true,
    "cmake.clearOutputBeforeBuild": true,
    "errorLens.enabled": true,
    "errorLens.messageEnabled": true,
    "errorLens.messageMaxChars": 140,
    "errorLens.excludeBySource": [
        "cSpell"
    ],
    "gitlens.currentLine.enabled": false,
    "gitlens.codeLens.enabled": false,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.cpp": "${capture}.h, ${capture}.hpp, ${capture}.hh, ${capture}.hxx, ${capture}.inl, ${capture}.ipp",
        "*.cc": "${capture}.h, ${capture}.hpp, ${capture}.hh, ${capture}.hxx, ${capture}.inl, ${capture}.ipp",
        "*.cxx": "${capture}.h, ${capture}.hpp, ${capture}.hh, ${capture}.hxx, ${capture}.inl, ${capture}.ipp",
        "*.c": "${capture}.h",
        "*.hpp": "${capture}.inl, ${capture}.ipp",
        "*.h": "${capture}.inl, ${capture}.ipp",
        "*.vert": "${capture}.vert.spv",
        "*.frag": "${capture}.frag.spv",
        "*.comp": "${capture}.comp.spv",
        "*.geom": "${capture}.geom.spv",
        "*.tesc": "${capture}.tesc.spv",
        "*.tese": "${capture}.tese.spv",
        "CMakeLists.txt": "CMakePresets.json, CMakeUserPresets.json"
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
    },
    "[glsl]": {
        "editor.formatOnSave": false,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "cSpell.customDictionaries": {
        "project-words": {
            "name": "project-words",
            "path": "${workspaceRoot}/project-words.txt",
            "description": "Words used in this project",
            "addWords": true
        },
        "custom": true, // Enable the `custom` dictionary
        "internal-terms": false // Disable the `internal-terms` dictionary
    }
}
